# Supabase — client (anon) credentials. Find these in your Supabase dashboard:
# Project Settings → API → Project URL and anon/public key.
# Copy this file to ".env" and fill in the values. NEVER put the service_role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend QA API (src/app.js)
VITE_API_URL=http://localhost:4000
